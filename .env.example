# Local dev only — copied to .gcloud/ by npm run generate-env after gcloud ADC login
GOOGLE_APPLICATION_CREDENTIALS=.gcloud/application_default_credentials.json
GCP_USER_EMAIL=
GCP_PROJECT_ID=
GCP_LOCATION=australia-southeast1

GCS_APP_BUCKET=
GCS_LOCATION=australia-southeast1
GCS_APP_PREFIX=releases

FIRESTORE_APP_COLLECTION=app_versions
FIRESTORE_APP_CATALOG=app_catalog

REGISTRY_API_SERVICE=nucleus-registry-api
AI_OVERVIEW_API_SERVICE=nucleus-ai-overview-api
WEBSITE_SERVICE=nucleus-website

# Nucleus AI Overview API (services/ai-overview-api)
AI_OVERVIEW_PUBLIC_URL=https://nucleus-ai.suherman.net
NUCLEUS_CLOUD_AUTH_REQUIRED=true
LLM_PROVIDER=vertex
VERTEX_LOCATION=us-central1
VERTEX_GOOGLE_SEARCH_GROUNDING=true
PLANNER_MODEL=gemini-2.5-flash
CONTEXT_MODEL=gemini-2.5-flash
REASONER_MODEL=gemini-2.5-pro
VERIFIER_MODEL=gemini-2.5-flash
# Local Ollama fallback (set LLM_PROVIDER=openai)
LLM_BASE_URL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=
ENABLE_VERIFIER=true
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
GITHUB_TOKEN=

NEXT_PUBLIC_REGISTRY_API_URL=
NEXT_PUBLIC_APP_ID=nucleus-macos
NEXT_PUBLIC_DOWNLOAD_BASE_URL=
PUBLIC_DOWNLOAD_BASE_URL=
WEBSITE_BASE_URL=
REGISTRY_API_PUBLIC_URL=
SPARKLE_APPCAST_URL=
DEFAULT_APP_ID=nucleus-macos

LOCAL_WEBSITE_URL=http://127.0.0.1:3000
LOCAL_DOWNLOAD_BASE_URL=http://127.0.0.1:3000/downloads
LOCAL_APPCAST_URL=http://127.0.0.1:3000/appcast.xml

# Nucleus Cloud Sync (website Next.js backend + Firestore)
NUCLEUS_SYNC_PUBLIC_URL=https://nucleus-sync.suherman.net
AUTH_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://nucleus-sync.suherman.net/api/auth/google/callback
WEBSITE_BASE_URL=https://nucleus-sync.suherman.net

# Apple CloudKit API token (https://icloud.developer.apple.com/dashboard). Seeded to GCP Secret Manager.
CLOUDKIT_MANAGEMENT_TOKEN=

# Developer ID provisioning profile for release signing (downloaded by npm run generate-env).
MACOS_DEVELOPER_ID_PROVISIONING_PROFILE=app/Nucleus/Nucleus_DeveloperID.provisionprofile
